---
import Section from "../Section.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { getCollection } from "astro:content";

const entries = (await getCollection("projects"))
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
const projects = entries.map((e) => ({ slug: e.id, ...e.data }));
---

<Section title="Mis proyectos">
  <ul class="grid grid-cols-1 sm:grid-cols-2 gap-5 items-stretch">
    {
      projects.slice(0, 4).map((project) => <ProjectCard project={project} />)
    }
  </ul>
  <div class="flex justify-end mt-6">
    <a
      href="/projects"
      class="group inline-flex items-center gap-2 rounded-full border border-[#ddd] px-4 py-2 text-sm font-medium transition duration-300 hover:bg-[#f5f5f5] hover:border-[#bbb]"
    >
      Ver todos los proyectos
      <span aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-1">→</span>
    </a>
  </div>
</Section>
