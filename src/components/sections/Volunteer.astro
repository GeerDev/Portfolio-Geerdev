---
import Section from "../Section.astro";
import Img from "@/components/Img.astro";

import { volunteer } from "@cv"
---

<Section title="Voluntariado">
  <ul class="flex flex-col gap-6">
    {
      volunteer.map(
        ({ organization, position, url, image, emoji, startDate, endDate, summary, highlights }) => {
          const startYear = new Date(startDate).getFullYear()
          const endYear = endDate != null ? new Date(endDate).getFullYear() : "Actual"

          return (
            <li>
              <article class="flex flex-col sm:flex-row gap-5 rounded-2xl border border-[#eee] bg-[#faf9f7] p-5 transition duration-300 hover:shadow-lg">
                {image && (
                  <figure class="shrink-0 overflow-hidden rounded-xl">
                    <Img
                      src={image}
                      alt={organization}
                      class="h-40 w-full sm:w-48 object-cover transition duration-500 hover:scale-105"
                      width={420}
                    />
                  </figure>
                )}

                <div class="flex flex-col gap-2">
                  <header class="flex flex-col gap-0.5">
                    <div class="flex items-baseline justify-between gap-4">
                      {url ? (
                        <a href={url} title={`Ver ${organization}`} target="_blank" rel="noopener noreferrer" class="font-black text-lg hover:underline">
                          <h3>{emoji} {organization}</h3>
                        </a>
                      ) : (
                        <h3 class="font-black text-lg">{emoji} {organization}</h3>
                      )}
                      <time class="text-sm text-[#888] shrink-0">{startYear} - {endYear}</time>
                    </div>
                    <h4 class="font-semibold text-sm text-[#666]">{position}</h4>
                  </header>

                  {summary && <p class="text-sm text-[#555]">{summary}</p>}

                  {highlights && highlights.length > 0 && (
                    <ul class="flex flex-wrap gap-2 mt-1">
                      {highlights.map((highlight) => (
                        <li class="rounded-full bg-white border border-[#eee] px-3 py-1 text-xs font-medium text-[#444]">
                          {highlight}
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              </article>
            </li>
          )
        }
      )
    }
  </ul>
</Section>
