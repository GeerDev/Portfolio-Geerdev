---
import Section from "../Section.astro";

import { work } from "@cv"
---

<Section title="Experiencia laboral">
  <ul class="flex flex-col gap-10">
    {
      work.map(
        ({ name, startDate, endDate, position, summary, url, highlights }) => {
          const startYear = new Date(startDate).getFullYear()
          const endYear = endDate != null ? new Date(endDate).getFullYear() : "Actual"

          return (
            <li>
              <article class="flex flex-col gap-3">
                <header class="flex flex-col gap-0.5">
                  <div class="flex items-baseline justify-between gap-4">
                    {url ? (
                      <a href={url} title={`Ver ${name}`} target="_blank" rel="noopener noreferrer" class="font-black text-lg hover:underline">
                        <h3>{name}</h3>
                      </a>
                    ) : (
                      <h3 class="font-black text-lg">{name}</h3>
                    )}
                    <time class="text-sm text-[#666] shrink-0">{startYear} - {endYear}</time>
                  </div>
                  <h4 class="font-semibold text-sm text-[#444]">{position}</h4>
                  {summary && <p class="text-sm text-[#888]">{summary}</p>}
                </header>

                {highlights && highlights.length > 0 && (
                  <ul class="flex flex-col gap-2">
                    {highlights.map((highlight) => (
                      <li class="flex gap-2.5 items-start">
                        <span class="text-[#44495A] mt-0.5 shrink-0" aria-hidden="true">▹</span>
                        <span class="font-medium text-[#222]">{highlight}</span>
                      </li>
                    ))}
                  </ul>
                )}
              </article>
            </li>
          )
        }
      )
    }
  </ul>
</Section>
