---
import Section from "../Section.astro";
import Img from "@/components/Img.astro";

import { awards } from "@cv"
---

<Section title="Certificaciones y Logros">
  <div class="grid grid-cols-2 gap-5">
    {
      awards.map(({ title, image, url }) => (
        <article class="flex flex-col items-center gap-3 border border-[#eee] rounded-lg p-4 transition duration-300 hover:shadow-lg">
          <figure class="flex items-center justify-center w-full h-28">
            <Img src={image} alt={title} class="max-h-full max-w-full object-contain" width={320} />
          </figure>
          {url ? (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-center text-sm font-medium hover:underline"
            >
              {title}
            </a>
          ) : (
            <p class="text-center text-sm font-medium">{title}</p>
          )}
        </article>
      ))
    }
  </div>
</Section>
