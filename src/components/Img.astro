---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { resolveImage } from "@/lib/images";

interface Props {
  src: string;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
  widths?: number[];
  format?: "webp" | "avif" | "png" | "jpeg";
  loading?: "lazy" | "eager";
}

const { src, alt, class: className, format = "webp", loading = "lazy", ...rest } = Astro.props;
const resolved = resolveImage(src);

const isMeta = typeof resolved !== "string";
// Los SVG (y las URLs remotas / rutas no resueltas) no pasan por <Image>:
// se renderizan como <img> normal. El resto se optimiza con astro:assets.
const isSvg = isMeta && (resolved as ImageMetadata).format === "svg";
const plainSrc = isMeta ? (resolved as ImageMetadata).src : (resolved as string);
---

{
  isMeta && !isSvg ? (
    <Image src={resolved as ImageMetadata} alt={alt} class={className} format={format} loading={loading} {...rest} />
  ) : (
    <img src={plainSrc} alt={alt} class={className} loading={loading} {...rest} />
  )
}
