---
import '../styles/global.css'

import { basics } from '@cv'
import meImg from '@/assets/images/hero/me.webp'

interface Props {
  title?: string
}

const { title = "Portfolio Germán Fernández Sierra" } = Astro.props
const { summary, url } = basics

// URL absoluta de la imagen optimizada para favicon y meta OG/Twitter.
const ogImage = new URL(meImg.src, url).href
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/webp" href={meImg.src} />
		<link rel="preload" as="image" href={meImg.src} />
		<title>{ title }</title>

		<meta name="description" content={summary} />

		<meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={summary} />
    <meta property="og:image" content={ogImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta property="twitter:domain" content={url.split("//")[1] ?? ''} />
    <meta property="twitter:url" content={url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={summary} />
    <meta name="twitter:image" content={ogImage} />
	</head>
	<body>
		<slot />
	</body>
</html>
