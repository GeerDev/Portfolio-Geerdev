---
import Layout from "@/layouts/Layout.astro";
import Section from "@/components/Section.astro";
import { Projects as ProjectsPage } from "@/components/all/Projects.tsx";
import { resolveImageSrc } from "@/lib/images";

import { basics, projects } from "@cv"
const { name, label } = basics

// Pre-resolvemos las imágenes aquí (en el .astro) y se las pasamos ya listas al
// componente React. Mismo patrón que blog.astro (recomendado por la doc de Astro:
// <Image/> no funciona dentro de componentes de framework).
const items = projects.map((project) => ({
  ...project,
  image: resolveImageSrc(project.image),
}))
---
<Layout title={`Portafolio de ${name} - ${label}`}>
  <main class="p-10">
    <section class="max-w-3xl mx-auto mb-5">
      <a href="/" class="text-sm text-blue-600 hover:underline transition">
        ← Volver al inicio
      </a>
    </section>
    <Section title="Todos mis proyectos" center>
      <ProjectsPage projects={items} client:visible />
    </Section>
  </main>
</Layout>
