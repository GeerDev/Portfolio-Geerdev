---
import Layout from "@/layouts/Layout.astro";
import Section from "@/components/Section.astro";
import ProjectCard from "@/components/ProjectCard.astro";

import { basics, projects } from "@cv"
const { name, label } = basics
---
<Layout title={`Portafolio de ${name} - ${label}`}>
  <main class="p-10">
    <section class="max-w-3xl mx-auto mb-5">
      <a href="/" class="text-sm text-blue-600 hover:underline transition">
        ← Volver al inicio
      </a>
    </section>
    <Section title="Todos mis proyectos">
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-5 items-stretch">
        {
          projects.map((project) => <ProjectCard project={project} />)
        }
      </ul>
    </Section>
  </main>
</Layout>
