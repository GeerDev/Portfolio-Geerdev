---
import Layout from "@/layouts/Layout.astro";
import Section from "@/components/Section.astro";
import { Blog as BlogPage } from "@/components/all/Blog.tsx";
import { resolveImageSrc } from "@/lib/images";
import { getCollection } from "astro:content";

import { basics } from "@cv"
const { name, label } = basics

// Fuente única: colección de contenido. Pre-resolvemos la imagen aquí (string)
// porque <Image/> no funciona dentro del componente React.
const entries = (await getCollection("blog"))
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));
const articles = entries.map((e) => ({
  slug: e.id,
  ...e.data,
  image: resolveImageSrc(e.data.image),
}))
---
<Layout title={`Portafolio de ${name} - ${label}`}>
  <main class="p-10">
    <section class="max-w-3xl mx-auto mb-5">
      <a href="/" class="text-sm text-blue-600 hover:underline transition">
        ← Volver al inicio
      </a>
    </section>
    <Section title="Todos mis artículos" center>
      <BlogPage articles={articles} client:visible />
    </Section>
  </main>
</Layout>
