---
import Layout from "@/layouts/Layout.astro";
import Section from "@/components/Section.astro";
import { Blog as BlogPage } from "@/components/all/Blog.tsx";
import { resolveImageSrc } from "@/lib/images";

import { basics, blog } from "@cv"
const { name, label } = basics

// Pre-resolvemos las imágenes aquí (en el .astro) y se las pasamos ya listas al
// componente React. Patrón recomendado por la documentación de Astro: <Image/> no
// funciona dentro de componentes de framework, así que se pre-optimiza en el padre.
const articles = blog.map((article) => ({
  ...article,
  image: resolveImageSrc(article.image),
}))
---
<Layout title={`Portafolio de ${name} - ${label}`}>
  <main class="p-10">
    <section class="max-w-3xl mx-auto mb-5">
      <a href="/" class="text-sm text-blue-600 hover:underline transition">
        ← Volver al inicio
      </a>
    </section>
    <Section title="Todos mis artículos" center>
      <BlogPage articles={articles} client:visible />
    </Section>
  </main>
</Layout>
