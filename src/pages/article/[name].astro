---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Section from "@/components/Section.astro";
import Img from "@/components/Img.astro";
import { basics } from "@cv";

export async function getStaticPaths() {
  const entries = await getCollection("blog");
  return entries.map((entry) => ({ params: { name: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { name: articleName, description, image, category, url } = entry.data;
const { name } = basics;
---

<Layout title={`${articleName} - ${name}`}>
  <main class="p-10">
    <section class="max-w-3xl mx-auto mb-5">
      <a id="back-link" href="/blog" class="text-sm text-blue-600 hover:underline transition">
        ← Volver al blog
      </a>
    </section>

    <script is:inline>
      // Enlace "volver" según el origen: si llegas desde la home, vuelve al
      // portfolio; en otro caso, vuelve al listado del blog (valor por defecto).
      const back = document.getElementById("back-link");
      if (back && document.referrer) {
        try {
          const from = new URL(document.referrer);
          if (from.origin === location.origin && from.pathname === "/") {
            back.setAttribute("href", "/");
            back.textContent = "← Volver al portfolio";
          }
        } catch {}
      }
    </script>

    <Section title={articleName} center>
      {category.length > 0 && (
        <ul class="flex flex-wrap justify-center gap-1.5 mb-5">
          {category.map((c) => (
            <li class="rounded-full bg-[#e8e8e8] px-2.5 py-0.5 text-xs font-semibold text-[#555]">{c}</li>
          ))}
        </ul>
      )}

      {image && (
        <figure class="rounded-xl overflow-hidden mb-6">
          <Img src={image} alt={articleName} class="w-full aspect-video object-cover" width={768} />
        </figure>
      )}

      <p class="text-[#666] text-lg mb-8">{description}</p>

      <article class="markdown-body">
        <Content />
      </article>

      {url && (
        <div class="flex justify-end mt-8">
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-2 rounded-full border border-[#ddd] px-4 py-2 text-sm font-medium transition duration-300 hover:bg-[#f5f5f5] hover:border-[#bbb]"
          >
            Leer fuente original
            <span aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-1">→</span>
          </a>
        </div>
      )}
    </Section>
  </main>
</Layout>
